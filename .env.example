# Discord Bot
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_application_client_id
DISCORD_CLIENT_SECRET=your_application_client_secret

# OAuth2 (Dashboard login) — from Developer Portal → OAuth2 (NOT the bot token)
# Client Secret: OAuth2 → Client Secret → Reset/Copy
# Redirect: add the same URI under OAuth2 → Redirects
OAUTH_REDIRECT_URI=http://localhost:3000/auth/discord/callback
OAUTH_SCOPES=identify guilds
DASHBOARD_URL=http://localhost:3000
DASHBOARD_LINK_TEXT=Open Admin Dashboard
DASHBOARD_EMBED_TITLE=Minnie XP Dashboard
DASHBOARD_EMBED_DESCRIPTION=Manage XP, levels, economy, and quests from the web panel. Server administrators only.

# API Server
API_PORT=4000
API_URL=http://localhost:4000
SESSION_SECRET=change_this_to_a_long_random_string
JWT_SECRET=change_this_jwt_secret_too

# Dashboard (Next.js) — browser uses same-origin /api proxy; do not set to :4000 for login cookies
# NEXT_PUBLIC_BROWSER_API_URL=
API_BACKEND_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=http://localhost:4000
NEXT_PUBLIC_DISCORD_CLIENT_ID=your_application_client_id

# Database
DATABASE_PATH=./data/minnie.db

# Bot defaults (overridden per-guild in DB)
DEFAULT_VOICE_XP_RATE=5
DEFAULT_TEXT_XP_MIN=5
DEFAULT_TEXT_XP_MAX=10
DEFAULT_TEXT_COOLDOWN=60
DEFAULT_DAILY_XP_CAP=500
DEFAULT_MIN_MESSAGE_LENGTH=3
DEFAULT_MAX_LEVEL=100
DEFAULT_PRESTIGE_MAX=10

# Environment
NODE_ENV=development

# Logging & crash recovery (supervisor)
LOG_DIR=./logs
LOG_LEVEL=info
RESTART_DELAY_MS=5000
MAX_RESTARTS=15
RESTART_WINDOW_MS=600000
